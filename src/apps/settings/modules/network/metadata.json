{
    "id": "network",
    "name": "Network",
    "icon": "network-workgroup",
    "group": "Connectivity",
    "description": "Wi-Fi, Ethernet, VPN, proxy, and firewall.",
    "keywords": ["wifi", "ethernet", "vpn", "proxy", "internet", "firewall", "security"],
    "main": "NetworkPage.qml",
    "settings": [
        {
            "id": "wifi",
            "label": "Wi-Fi",
            "description": "Enable and manage wireless networks",
            "keywords": ["wifi", "wireless", "ssid"],
            "type": "toggle",
            "backend_binding": "dbus:org.freedesktop.NetworkManager/WirelessEnabled",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "ethernet",
            "label": "Ethernet Status",
            "description": "Check wired connectivity",
            "keywords": ["ethernet", "lan", "cable"],
            "type": "action",
            "backend_binding": "dbus:org.freedesktop.NetworkManager",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "vpn",
            "label": "VPN",
            "description": "Add and manage VPN profiles",
            "keywords": ["vpn", "private network"],
            "type": "action",
            "backend_binding": "dbus:org.freedesktop.NetworkManager.Settings",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "firewall-enabled",
            "label": "Firewall",
            "description": "Enable desktop firewall service",
            "keywords": ["firewall", "security", "incoming"],
            "type": "toggle",
            "backend_binding": "dbus:org.slm.Desktop.Firewall",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "firewall-mode",
            "label": "Firewall Mode",
            "description": "Set firewall profile: Home, Public, or Custom",
            "keywords": ["firewall", "mode", "home", "public", "custom"],
            "type": "choice",
            "backend_binding": "dbus:org.slm.Desktop.Firewall",
            "privileged_action": "org.slm.settings.network.modify"
        }
    ]
}
