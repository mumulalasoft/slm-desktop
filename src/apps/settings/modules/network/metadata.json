{
    "id": "network",
    "name": "Network",
    "icon": "network-workgroup",
    "group": "Connectivity",
    "description": "Wi-Fi, Ethernet, VPN, and proxy.",
    "keywords": ["wifi", "ethernet", "vpn", "proxy", "internet"],
    "main": "NetworkPage.qml",
    "settings": [
        {
            "id": "wifi",
            "label": "Wi-Fi",
            "description": "Enable and manage wireless networks",
            "keywords": ["wifi", "wireless", "ssid"],
            "type": "toggle",
            "backend_binding": "dbus:org.freedesktop.NetworkManager/WirelessEnabled",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "ethernet",
            "label": "Ethernet Status",
            "description": "Check wired connectivity",
            "keywords": ["ethernet", "lan", "cable"],
            "type": "action",
            "backend_binding": "dbus:org.freedesktop.NetworkManager",
            "privileged_action": "org.slm.settings.network.modify"
        },
        {
            "id": "vpn",
            "label": "VPN",
            "description": "Add and manage VPN profiles",
            "keywords": ["vpn", "private network"],
            "type": "action",
            "backend_binding": "dbus:org.freedesktop.NetworkManager.Settings",
            "privileged_action": "org.slm.settings.network.modify"
        }
    ]
}
