[Unit]
Description=SLM Environment Variable Daemon
Documentation=https://gitlab.com/slm/desktop-shell/-/blob/main/docs/ENVD_ARCHITECTURE.md
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/slm-envd
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
