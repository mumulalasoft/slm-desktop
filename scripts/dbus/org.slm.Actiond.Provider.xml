    <method name="RegisterProvider"><arg name="provider_id" type="s" direction="in"/><arg name="app_id" type="s" direction="in"/><arg name="capabilities" type="a{sv}" direction="in"/><arg type="b" direction="out"/></method>
    <method name="UnregisterProvider"><arg name="provider_id" type="s" direction="in"/><arg type="b" direction="out"/></method>
    <method name="RegisterContext"><arg name="provider_id" type="s" direction="in"/><arg name="context" type="a{sv}" direction="in"/><arg type="b" direction="out"/></method>
    <method name="UpdateContext"><arg name="provider_id" type="s" direction="in"/><arg name="context" type="a{sv}" direction="in"/><arg type="b" direction="out"/></method>
    <method name="ActivateContext"><arg name="context_id" type="s" direction="in"/><arg type="b" direction="out"/></method>
    <method name="DeactivateContext"><arg name="context_id" type="s" direction="in"/><arg type="b" direction="out"/></method>
    <method name="SetActions"><arg name="provider_id" type="s" direction="in"/><arg name="context_id" type="s" direction="in"/><arg name="actions" type="aa{sv}" direction="in"/><arg type="b" direction="out"/></method>
    <method name="UpdateAction"><arg name="provider_id" type="s" direction="in"/><arg name="context_id" type="s" direction="in"/><arg name="action_id" type="s" direction="in"/><arg name="patch" type="a{sv}" direction="in"/><arg type="b" direction="out"/></method>
