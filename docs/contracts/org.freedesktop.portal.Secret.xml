<!DOCTYPE node PUBLIC
  "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/freedesktop/portal/desktop">
  <interface name="org.freedesktop.portal.Secret">
    <!-- Async Request-style portal methods -->
    <method name="StoreSecret">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="options" type="a{sv}" direction="in"/>
      <arg name="secret" type="ay" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <method name="GetSecret">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="query" type="a{sv}" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <method name="DeleteSecret">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="query" type="a{sv}" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <method name="ClearAppSecrets">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="options" type="a{sv}" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <method name="GrantAccess">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="rule" type="a{sv}" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <method name="UnlockSecrets">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="options" type="a{sv}" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>

    <!-- Sync metadata/control -->
    <method name="DescribeSecret">
      <arg name="query" type="a{sv}" direction="in"/>
      <arg name="metadata" type="a{sv}" direction="out"/>
    </method>
    <method name="ListOwnSecretMetadata">
      <arg name="options" type="a{sv}" direction="in"/>
      <arg name="items" type="aa{sv}" direction="out"/>
    </method>
    <method name="RevokeAccess">
      <arg name="rule" type="a{sv}" direction="in"/>
      <arg name="ok" type="b" direction="out"/>
    </method>
    <method name="LockSecrets">
      <arg name="options" type="a{sv}" direction="in"/>
      <arg name="ok" type="b" direction="out"/>
    </method>

    <signal name="SecretAccessed">
      <arg name="app_id" type="s"/>
      <arg name="action" type="s"/>
      <arg name="namespace_name" type="s"/>
      <arg name="key" type="s"/>
      <arg name="timestamp_ms" type="t"/>
    </signal>
    <signal name="SecretsLockStateChanged">
      <arg name="locked" type="b"/>
    </signal>
  </interface>
</node>

