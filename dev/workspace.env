#!/usr/bin/env bash
# dev/workspace.env — Environment variables untuk sesi development lokal SLM.
#
# Cara pakai:
#   source /path/to/desktop-shell/dev/workspace.env
#
# Atau otomatis di run-dev.sh.

# ── Workspace root ────────────────────────────────────────────────────────────
# Asumsikan struktur:
#   /workspace/
#     desktop-shell/   ← repo ini
#     filemanager/     ← repo slm-filemanager
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export SLM_WORKSPACE="${SLM_WORKSPACE:-$(dirname "$SCRIPT_DIR")}"
export SLM_DESKTOP_SOURCE_DIR="$SCRIPT_DIR/.."

# ── FileManager paths ─────────────────────────────────────────────────────────
export SLM_FILEMANAGER_SOURCE_DIR="${SLM_FILEMANAGER_SOURCE_DIR:-$(dirname "$SLM_WORKSPACE")/filemanager}"
export SLM_FILEMANAGER_BUILD_DIR="${SLM_FILEMANAGER_BUILD_DIR:-$SLM_FILEMANAGER_SOURCE_DIR/build/dev}"
export SLM_FILEMANAGER_INSTALL_DIR="${SLM_FILEMANAGER_INSTALL_DIR:-$SLM_FILEMANAGER_BUILD_DIR/install}"

# Binary override — shell akan prefer binary lokal bila tersedia
export SLM_FILEMANAGER_BINARY="${SLM_FILEMANAGER_BINARY:-$SLM_FILEMANAGER_BUILD_DIR/slm-filemanager}"
export SLM_FILEOPSD_BINARY="${SLM_FILEOPSD_BINARY:-$SLM_FILEMANAGER_BUILD_DIR/slm-fileopsd}"

# Desktop shell build dir
export SLM_DESKTOP_BUILD_DIR="${SLM_DESKTOP_BUILD_DIR:-$SLM_DESKTOP_SOURCE_DIR/../build/dev}"

# ── QML import paths ──────────────────────────────────────────────────────────
# Prioritaskan QML dari local build
_FM_QML="$SLM_FILEMANAGER_INSTALL_DIR/lib/qt6/qml"
if [[ -d "$_FM_QML" ]]; then
    export QML2_IMPORT_PATH="$_FM_QML${QML2_IMPORT_PATH:+:$QML2_IMPORT_PATH}"
    export QML_IMPORT_PATH="$_FM_QML${QML_IMPORT_PATH:+:$QML_IMPORT_PATH}"
fi

# ── Library paths ─────────────────────────────────────────────────────────────
_FM_LIB="$SLM_FILEMANAGER_INSTALL_DIR/lib"
if [[ -d "$_FM_LIB" ]]; then
    export LD_LIBRARY_PATH="$_FM_LIB${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

# ── Logging ───────────────────────────────────────────────────────────────────
# Semua kategori slm.* aktif secara default di dev mode.
# Override dengan QT_LOGGING_RULES sebelum source file ini bila ingin lebih spesifik.
export QT_LOGGING_RULES="${QT_LOGGING_RULES:-slm.*=true}"

# Format log: waktu + kategori
export QT_MESSAGE_PATTERN="${QT_MESSAGE_PATTERN:-%{time hh:mm:ss.zzz} %{category} %{message}}"

# Level log internal SLM
export SLM_LOG_LEVEL="${SLM_LOG_LEVEL:-debug}"

# ── Dev mode flags ────────────────────────────────────────────────────────────
export SLM_DEV_MODE=1

# Izinkan filemanager multi-instance saat development (skip singleton check)
export SLM_FM_SKIP_SINGLETON_CHECK="${SLM_FM_SKIP_SINGLETON_CHECK:-1}"

# Aktifkan request ID di setiap log entry lintas komponen
export SLM_REQUEST_TRACE="${SLM_REQUEST_TRACE:-1}"

# Matikan thumbnail cache agar tidak stale saat iterasi cepat
export SLM_DISABLE_THUMBNAIL_CACHE="${SLM_DISABLE_THUMBNAIL_CACHE:-0}"

# ── Testing overrides ─────────────────────────────────────────────────────────
export SLM_TEST_FILEOPSD_SOCKET="${SLM_TEST_FILEOPSD_SOCKET:-/tmp/slm-fileopsd-test.sock}"
export SLM_FAKE_MOUNTS_DIR="${SLM_FAKE_MOUNTS_DIR:-/tmp/slm-fake-mounts}"

# ── DBus activation override ──────────────────────────────────────────────────
# Beritahu shell untuk prefer binary lokal daripada yang terinstall sistem
export SLM_DBUS_FILEMANAGER_OVERRIDE="$SLM_FILEMANAGER_BINARY"
export SLM_DBUS_FILEOPSD_OVERRIDE="$SLM_FILEOPSD_BINARY"

# ── Ringkasan ─────────────────────────────────────────────────────────────────
if [[ "${SLM_ENV_QUIET:-0}" != "1" ]]; then
    echo "[slm-dev] workspace.env loaded"
    echo "  FM source  : $SLM_FILEMANAGER_SOURCE_DIR"
    echo "  FM build   : $SLM_FILEMANAGER_BUILD_DIR"
    echo "  Desktop    : $SLM_DESKTOP_BUILD_DIR"
fi
